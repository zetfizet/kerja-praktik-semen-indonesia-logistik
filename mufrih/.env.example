# Local environment template. Copy to .env and fill in your values.

# Airflow secrets
AIRFLOW_SECRET_KEY=your-secret-key-here-generate-new-one
AIRFLOW_FERNET_KEY=your-fernet-key-here-generate-new-one

# Local Postgres password used by the compose stack
POSTGRES_PASSWORD=your-postgres-password

# GraphHopper routing settings
GRAPHHOPPER_API_KEY=your-graphhopper-api-key
GRAPHHOPPER_BASE_URL=https://graphhopper.com/api/1
GRAPHHOPPER_ALLOW_FALLBACK=false

# Optional source database overrides
# SOURCE_DB_HOST=192.168.1.100
# SOURCE_DB_PORT=1433
# SOURCE_DB_USER=your-user
# SOURCE_DB_PASSWORD=your-password
# SOURCE_DB_NAME=office
