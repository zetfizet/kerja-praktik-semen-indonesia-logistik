"""
Warehouse Sync DAG with DELETION TRACKING - Enhanced Version
==============================================================

NEW FEATURES:
✅ #1: Soft Delete Support - Auto-sync deleted_at column
✅ #2: Hard Delete Detection - Find orphaned records in warehouse
✅ #3: Deletion Strategy - Mark as deleted or remove from warehouse

Supports BOTH:
- Soft Delete (deleted_at column in source)
- Hard Delete (record removed from source)

Total: 88 tables + deletion tracking
Schedule: 2 AM daily
"""

from airflow import DAG
from airflow.providers.standard.operators.python import PythonOperator
from airflow.providers.standard.operators.bash import BashOperator
from datetime import datetime, timedelta
import psycopg2
