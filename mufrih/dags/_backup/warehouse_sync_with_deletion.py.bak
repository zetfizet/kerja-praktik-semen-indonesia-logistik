    'owner': 'data_team',
    'retries': 2,
    'retry_delay': timedelta(minutes=5),
    'start_date': datetime(2026, 2, 6),
}

# DAG definition
dag = DAG(
    'warehouse_sync_with_deletion',
    default_args=default_args,
    description='🗑️ Warehouse sync with soft/hard deletion tracking',
    schedule='0 2 * * *',
    catchup=False,
    tags=['warehouse', 'analytics', 'deletion', 'optimized'],
)

