# Airflow Secrets - Copy to .env and change values!
AIRFLOW_SECRET_KEY=your-secret-key-here-generate-new-one
AIRFLOW_FERNET_KEY=your-fernet-key-here-generate-new-one
POSTGRES_PASSWORD=your-postgres-password

